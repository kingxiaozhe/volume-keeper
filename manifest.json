{
  "manifest_version": 3,
  "key": "",
  "name": "Volume Keeper",
  "version": "0.2.0",
  "description": "Boost or lower volume per site — remembers your setting for each website, never breaks fullscreen.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "run_at": "document_start",
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume Keeper"
  }
}
